{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/ai-individuals", "destination": "/services", "permanent": true },
    { "source": "/ai-individuals.html", "destination": "/services", "permanent": true },
    { "source": "/levels-of-ai", "destination": "/methodology", "permanent": true },
    { "source": "/levels-of-ai.html", "destination": "/methodology", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
